options.default_width = 10

# Show row number by default: https://github.com/saulpw/visidata/issues/1536#issuecomment-1255709940
options.disp_rstatus_fmt += '  {sheet.cursorRowIndex}/{sheet.nRows}'

# https://github.com/saulpw/visidata/blob/stable/docs/customize.md#example-bind-i-to-edit-cell-globally
TableSheet.unbindkey('i')
TableSheet.bindkey('i', 'edit-cell')

# https://github.com/saulpw/visidata/blob/stable/docs/customize.md#customizing-cell-editing-keybindings
vd.editCellBindings['Enter'] = acceptThenFunc('go-down', 'edit-cell')


# https://github.com/saulpw/visidata/blob/stable/docs/customize.md#creating-new-commands
Sheet.addCommand('Ctrl+D', 'scroll-halfpage-down', 'cursorDown(nScreenRows//2); sheet.topRowIndex += nScreenRows//2')


# https://github.com/saulpw/visidata/blob/stable/docs/customize.md#turning-off-motd-motd
options.motd_url=''
