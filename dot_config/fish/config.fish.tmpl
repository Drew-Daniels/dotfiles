if not status is-interactive
    return
end

# ------- Paths -------

if is-macos
    fish_add_path /opt/homebrew/bin
    fish_add_path /usr/local/sbin
    fish_add_path "$HOME/.config/vscode-xml"
    fish_add_path $HOME/.rd/bin

    set -gx ANDROID_HOME $HOME/Library/Android/sdk
    fish_add_path $ANDROID_HOME/platform-tools
end

{{ if eq .chezmoi.os "linux" }}
fish_add_path /opt/nvim-linux-x86_64/bin
{{ end }}

fish_add_path $PNPM_HOME
fish_add_path "$VCPKG_ROOT"
fish_add_path "/opt/apache-maven-3.8.5/bin"
fish_add_path "$HOME/.pub-cache/bin"
fish_add_path "$HOME/.bun/bin"
fish_add_path "$HOME/.local/bin"

# ------- Theme -------

if is-linux
    set computerName (hostnamectl hostname)
    set theme (jq --raw-output '.theme' ~/.local/state/theme-toggle/state.json)
    setup-theme $theme
else if is-freebsd
    set computerName (hostname)
else if is-macos
    set computerName (scutil --get ComputerName)
    defaults read "Apple Global Domain" AppleInterfaceStyle &>/dev/null
    set -l os_theme_query_status $status
    if test $os_theme_query_status -eq 0
        setup-theme dark
    else
        setup-theme light
    end
end

# ------- Tools -------

if is-linux
    if command -q mise
        mise activate fish | source
    end
else if is-freebsd
    if command -q mise
        mise activate fish | source
    end
else if is-macos
    /opt/homebrew/bin/mise activate fish | source
    set -gx MISE_ENV development
end

starship init fish | source

set -gx FZF_DEFAULT_COMMAND "fd --type f"
fzf_configure_bindings --directory=\cf --processes=\cp --git_status=\cs --git_log=\cl --variables=\cv --history=\ch

zoxide init --cmd j fish | source
direnv hook fish | source

function __fish_complete_pip
    set -lx COMP_WORDS (commandline -o) ""
    set -lx COMP_CWORD ( \
        math (contains -i -- (commandline -t) $COMP_WORDS)-1 \
    )
    set -lx PIP_AUTO_COMPLETE 1
    string split \  -- (eval $COMP_WORDS[1])
end
complete -fa "(__fish_complete_pip)" -c pip

# ------- Environment variables -------

set -gx EDITOR nvim
set -gx VISUAL nvim
set -gx PROJECTS_DIR "$HOME/projects"
set -g fish_greeting
set -gx VIMCONFIG "$HOME/.config/nvim"
set -gx VIMDATA "$HOME/.local/share/nvim"
set -gx MUX_LAYOUT main-horizontal
set -gx XDG_CONFIG_HOME "$HOME/.config"
set -gx VCPKG_ROOT "$PROJECTS_DIR/vcpkg"
set -gx SOLARGRAPH_GLOBAL_CONFIG "$HOME/.config/solargraph/config.yml"
set -gx SNACKS_GHOSTTY true
set -gx PODMAN_COMPOSE_WARNING_LOGS false

{{ if eq .chezmoi.os "linux" }}
set -gx BROWSER qutebrowser
{{ end }}

if test -f ~/.env.fish
    source ~/.env.fish
else
    echo "No ~/.env.fish found. Run ~/scripts/export_secrets.sh"
end

# ------- Completions and aliases -------

op completion fish | source

{{ if eq .homeOrWork "work" }}
jira completion fish | source
{{ end }}

{{ if (and (eq .chezmoi.os "darwin") (eq .homeOrWork "home")) }}
atuin init fish | source

alias docker 'podman'
{{ end }}

{{ if eq .chezmoi.os "darwin" }}
alias bat "bat --theme 'auto:system' --theme-dark 'gruvbox-dark' --theme-light 'zenbones'"
{{ end }}

alias draw.io "/Applications/draw.io.app/Contents/MacOS/draw.io"
alias ncmpcpp 'ncmpcpp -b ~/.config/ncmpcpp/bindings'
alias claude 'claude --model "claude-opus-4-6[1m]"'

