[core]
	editor = nvim
	autocrlf = false
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[user]
	name = Drew Daniels
[init]
	defaultBranch = main
[credential]
	helper = osxkeychain
[checkout]
	defaultRemote = origin
[tag]
  sort = -version:refname
